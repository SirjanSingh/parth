 """
 RL environment for the RIS-MISO system.
 
+Key design: action = N phase angles only (not G).
+G is computed analytically via MMSE beamformer given the phases.
+This reduces action_dim from 2*M*K+2*N (~8000) to just N (4-64),
+making DDPG tractable in 200-500 episodes.
+
 Episode:  one fixed channel realization (H1, H2).
-Step:     agent outputs (G, phases); env returns sum rate as reward.
-State:    [H1_re, H1_im, H2_re, H2_im, G_re, G_im, phase_re, phase_im]
-Action:   [G_re, G_im, phase_re, phase_im]  (after actor normalisation)
+Step:     agent outputs N phase values (cos/sin encoded); env computes
+          G via MMSE, returns sum rate as reward.
+State:    [H1_re, H1_im, H2_re, H2_im, phase_cos, phase_sin]
+Action:   [cos(theta_1..N), sin(theta_1..N)]  — 2*N values in [-1,1]
 """
 
 import numpy as np
@@ -12,69 +18,70 @@ from .channels import generate_channels
 from .metrics import build_phi, compute_effective_channel, compute_sum_rate
 
 
+def _mmse_beamformer(H_eff: np.ndarray, Pt: float, sigma2: float) -> np.ndarray:
+    """Regularized ZF / MMSE beamformer, power-normalised to tr(GG^H)=Pt."""
+    K = H_eff.shape[0]
+    reg = K * sigma2 / (Pt + 1e-12)
+    G = H_eff.conj().T @ np.linalg.inv(H_eff @ H_eff.conj().T + reg * np.eye(K))
+    power = np.real(np.trace(G @ G.conj().T))
+    return G * np.sqrt(Pt / (power + 1e-12))
+
+
 class RIS_MISO_Env:
     def __init__(self, M: int, N: int, K: int, Pt: float, sigma2: float):
         self.M, self.N, self.K = M, N, K
         self.Pt, self.sigma2 = Pt, sigma2
 
-        # state: 2*(N*M + N*K + M*K + N)

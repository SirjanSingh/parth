+        self.state_dim  = 2 * N * M + 2 * N * K + 2 * N
+        # Action: cos/sin encoding of N phase angles → 2*N values in [-1, 1]
+        self.action_dim = 2 * N
 
-        self.H1 = self.H2 = self.G = self.phases = None
+        self.H1 = self.H2 = self.phases = None
 

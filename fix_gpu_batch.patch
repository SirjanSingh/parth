@@ -94,6 +95,15 @@ class DDPG:
         self.actor.train()
         return a
 
+    def select_action_batch(self, states: np.ndarray) -> np.ndarray:
+        """Batched action — states shape (B, state_dim), returns (B, action_dim)."""
+        self.actor.eval()
+        with torch.no_grad():
+            s = torch.FloatTensor(states).to(self.device)
+            a = self.actor(s).cpu().numpy()
+        self.actor.train()
+        return a

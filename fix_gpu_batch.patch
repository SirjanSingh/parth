+#!/bin/bash
+# ─────────────────────────────────────────────────────────────────────────────
+# run_drl_parallel.sh  —  train all 5 N values in parallel on separate GPUs
+#
+# Usage:
+#   chmod +x run_drl_parallel.sh
+#   ./run_drl_parallel.sh           # uses GPUs 3,4,5,6,7 (one per N)
+#   ./run_drl_parallel.sh --quick   # 200 eps x 500 steps (sanity check, ~5 min)
+#
+# Each N value gets its own GPU. Logs go to logs/drl_N{N}.log
+# Run 'tail -f logs/drl_N64.log' to monitor any job.
+# ─────────────────────────────────────────────────────────────────────────────
+
+set -e
+mkdir -p logs results models
+
+# Parse --quick flag
+QUICK=0
+for arg in "$@"; do [[ "$arg" == "--quick" ]] && QUICK=1; done
+
+if [[ $QUICK -eq 1 ]]; then
+    NUM_EPS=200
+    STEPS_EP=500
+    echo "Quick mode: ${NUM_EPS} eps x ${STEPS_EP} steps per N"
+else
+    NUM_EPS=500
+    STEPS_EP=1000
+    echo "Full mode: ${NUM_EPS} eps x ${STEPS_EP} steps per N"
+fi
+
+# GPU assignment: use GPUs 3-7 (0,1,2 are busy per nvidia-smi)
+# Adjust if your allocation is different
+GPUS=(3 4 5 6 7)
+N_VALS=(4 8 16 32 64)
+
+# Kill existing training jobs if re-running
+pkill -f "train_drl.py" 2>/dev/null || true
+sleep 1
+
+# Delete old DRL results so we don't append to garbage
+rm -f results/drl_M64_K64.npz
+echo "Cleared old DRL results."
+echo ""
+
+PIDS=()
+for i in "${!N_VALS[@]}"; do
+    N=${N_VALS[$i]}
+    GPU=${GPUS[$i]}
+    LOG="logs/drl_N${N}.log"
+
+    echo "Launching N=${N} on GPU ${GPU}  →  ${LOG}"
+    CUDA_VISIBLE_DEVICES=${GPU} python train_drl.py \
+        --N ${N} \
+        --num_eps ${NUM_EPS} \
+        --steps_ep ${STEPS_EP} \
+        > "${LOG}" 2>&1 &
+    PIDS+=($!)
+done
+
+echo ""
+echo "All 5 jobs launched. PIDs: ${PIDS[*]}"
+echo ""
+echo "Monitor with:"
+echo "  tail -f logs/drl_N64.log"
+echo "  watch -n5 'tail -1 logs/drl_N*.log'"
+echo ""
+echo "Wait for all jobs to finish..."
+
+# Wait and report
+FAILED=0
+for i in "${!PIDS[@]}"; do
+    PID=${PIDS[$i]}
+    N=${N_VALS[$i]}
+    if wait $PID; then
+        echo "  N=${N}: DONE ✓"
+    else
+        echo "  N=${N}: FAILED ✗  (check logs/drl_N${N}.log)"
+        FAILED=1
+    fi
+done
+
+echo ""
+if [[ $FAILED -eq 0 ]]; then
+    echo "All jobs completed successfully."
+    echo "Run: python plot_fig5.py"
+else
+    echo "Some jobs failed — check logs above."
+fi
